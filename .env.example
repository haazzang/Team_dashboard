# Telegram BotFather token
TELEGRAM_BOT_TOKEN=123456789:replace_with_your_token

# Restrict bot to a single chat (optional). Example group chat id:
TELEGRAM_CHAT_ID=-4914264496

# DeepSeek API key
DEEPSEEK_API_KEY=replace_with_your_deepseek_key

# Financial Modeling Prep (FMP) API key
FMP_API_KEY=replace_with_your_fmp_key

# Gmail IMAP (for auto-downloading JMLNKWGE swap report attachments)
# 1) Enable 2FA: https://myaccount.google.com/security
# 2) Create an app password: https://myaccount.google.com/apppasswords
# 3) Paste the 16-char password below (spaces are stripped automatically)
GMAIL_USER=your_account@gmail.com
GMAIL_APP_PASSWORD=replace_with_16_char_app_password

# Optional: DeepSeek/OpenAI-compatible settings
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TEMPERATURE=0.2
# DEEPSEEK_MAX_TOKENS=900

# Optional: FMP base url
# FMP_BASE_URL=https://financialmodelingprep.com

# Bot behavior
# GROUP_REQUIRE_MENTION=true
# DEFAULT_LOOKBACK_DAYS=180
# MAX_PREVIEW_ROWS=12
