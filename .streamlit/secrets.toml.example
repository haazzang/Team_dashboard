# Copy this file to .streamlit/secrets.toml locally, or paste these keys into
# Streamlit Community Cloud → Settings → Secrets for the deployed app.
#
# The Swap Report Analysis page reads these via st.secrets / os.environ
# fallback chain. Local env vars take precedence if both are set.

# --- Gmail IMAP (App Password, NOT your normal login) ---
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER         = "your.account@gmail.com"
GMAIL_APP_PASSWORD = "abcd efgh ijkl mnop"

# --- FMP (Financial Modeling Prep) for SMT.L EOD price ---
# Free tier at: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY = "your_fmp_api_key"

# --- Optional: Telegram alerts after Gmail fetch ---
# TELEGRAM_BOT_TOKEN = "123456:bot-token"
# TELEGRAM_CHAT_ID   = "123456789"
